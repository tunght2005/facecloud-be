{
  "info": {
    "_postman_id": "2f8d5d71-3f2e-4c2d-b9f3-1b4fddecb35d",
    "name": "FaceCloud BE APIs",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Collection for FaceCloud backend: auth, face register/verify, attendance scan"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "attendanceSessionId",
      "value": "1"
    },
    {
      "key": "imageBase64",
      "value": "data:image/jpeg;base64,PASTE_YOUR_BASE64_IMAGE_HERE"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student01@example.com\",\n  \"password\": \"123456\",\n  \"full_name\": \"Student Demo\",\n  \"user_code\": \"SV001\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            }
          },
          "response": []
        },
        {
          "name": "Login (Save Token)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student01@example.com\",\n  \"password\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "if (json && json.token) {",
                  "    pm.collectionVariables.set('token', json.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "response": []
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "me"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Face",
      "item": [
        {
          "name": "Face Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"imageBase64\": \"{{imageBase64}}\",\n  \"face_image_url\": null\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/face/register",
              "host": ["{{baseUrl}}"],
              "path": ["face", "register"]
            }
          },
          "response": []
        },
        {
          "name": "Face Verify",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"imageBase64\": \"{{imageBase64}}\",\n  \"captured_image_url\": null\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/face/verify",
              "host": ["{{baseUrl}}"],
              "path": ["face", "verify"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Attendance",
      "item": [
        {
          "name": "Attendance Scan",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"imageBase64\": \"{{imageBase64}}\",\n  \"attendance_session_id\": {{attendanceSessionId}},\n  \"captured_image_url\": null\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/attendance/scan",
              "host": ["{{baseUrl}}"],
              "path": ["attendance", "scan"]
            }
          },
          "response": []
        }
      ]
    }
  ]
}
